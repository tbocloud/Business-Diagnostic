# ── Copy this file to .env and fill in your values ────────
# cp .env.example .env

# OpenAI — get from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-key-here

# MySQL Database
# Local (XAMPP):         host=localhost, port=3306, user=root, password=(empty)
# Railway (production):  copy values from Railway MySQL service → Variables tab
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=biz_diagnostic
